#!/bin/bash
set -euo pipefail

dir="{{ .chezmoi.homeDir }}/.local/share/menubar"
bin="$dir/menubar"
plist="{{ .chezmoi.homeDir }}/Library/LaunchAgents/com.yuto.menubar.plist"
label="com.yuto.menubar"

: sources_sha256 {{ list (include "dot_local/share/menubar/main.swift") (include "dot_local/share/menubar/controller.swift") (include "dot_local/share/menubar/claude-usage.swift") (include "dot_local/share/menubar/github-prs.swift") | join "" | sha256sum }}

swiftc -O "$dir"/*.swift -o "$bin"

domain="gui/$(id -u)"

# bootout is asynchronous: it returns before the service is fully torn down.
# Bootstrapping while the old service is still unloading fails with
# "5: Input/output error", so wait for the service to actually disappear.
launchctl bootout "$domain/$label" 2>/dev/null || true
for _ in $(seq 1 50); do
	launchctl print "$domain/$label" >/dev/null 2>&1 || break
	sleep 0.1
done

launchctl bootstrap "$domain" "$plist"
launchctl kickstart -k "$domain/$label"
