{
  "cleanupPeriodDays": 1095,
  "env": {
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "{{ onepasswordRead "op://Private/Claude Code OTel endpoint/notesPlain" "T3XVGBQA4RARTJY6RQA2NDNZYI" }}"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Edit",
      "Bash(ls:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)"
    ],
    "deny": [
      "WebSearch",
      "NotebookEdit",
      "WorktreeCreate",
      "WorktreeDelete",
      "EnterWorktree",
      "ExitWorktree",
      "mcp__sentry__whoami",
      "mcp__sentry__find_organizations",
      "mcp__sentry__find_teams",
      "mcp__sentry__analyze_issue_with_seer"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/shell_env/session-start.ts",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-fork/session-start.ts",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/review-agent/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/user-prompt-submit.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ng-checker/pre-tool-use.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify/notification.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify/stop.ts",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/stop.ts",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/review-agent/hooks/stop.sh"
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "prompt",
            "model": "claude-opus-4-7[1m]",
            "timeout": 60,
            "prompt": "You are auditing the assistant's final response for laziness, unverified claims, and time-wasting questions.\n\nThe assistant's final response is in the `last_assistant_message` field of the hook input. If that field is missing or empty, allow the stop.\n\nBlock the stop if the assistant's final response contains ANY of:\n\n1. Lazy or incomplete work:\n   - Literal TODO/FIXME/XXX markers left for later\n   - Phrases like \"for now\", \"placeholder\", \"stub\", \"left as an exercise\", \"you can implement\", \"would need to\", \"in a real implementation\", \"simplified version\", \"honest XXX\", \"caveat\", \"cannot do XXX\"\n   - Half-implemented functions, mock returns, hardcoded values where real logic was requested\n   - Acknowledging an edge case but not handling it\n   - Skipping requested steps with excuses (\"this should work\", \"likely correct\", \"probably fine\")\n\n2. Unverified claims:\n   - Asserting code works without running it, building it, or testing it\n   - Asserting a file exists, a command succeeds, or an API behaves a certain way without showing tool output that proves it\n   - \"This should fix the issue\" / \"this will work\" without evidence\n   - Citing line numbers, function signatures, or behavior the assistant did not actually read or execute in this turn\n\n3. Time-wasting questions instead of action:\n   - \"Want me to investigate X?\", \"Should I look into Y?\", \"Do you want me to check Z?\"\n   - Asking permission for read-only operations (reading files, running grep, listing directories, git status, etc.)\n   - Asking the user to choose between options the assistant could have determined itself by reading the codebase\n   - Asking what the user wants instead of proposing options with tradeoffs backed by evidence\n\nAllow the stop when:\n   - The assistant genuinely needs a human decision (destructive action, ambiguous business requirement, missing credentials)\n   - The assistant proposes 2+ concrete options with tradeoffs and asks which to take\n   - The assistant verified its work with tool output included in the response\n   - The user's task is genuinely complete and proven\n\nWhen blocking, the reason MUST:\n   - Quote the specific offending text from the response\n   - State exactly what the assistant must do next: which file to read, which command to run, which option to commit to with rationale\n   - Be 1-3 sentences, directive and concrete"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/subagent-start.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/subagent-stop.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-fork/session-end.ts",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/session-end.ts",
            "timeout": 300
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js",
    "padding": 0
  },
  "enabledPlugins": {
    "todo-enforcer@harness": false,
    "comment-checker@harness": true,
    "typescript-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": false,
    "ci-watcher-channel@harness": true,
    "ultra-debug@harness": true,
    "dinii-kpi@dinii-plugin-market": true,
    "slack-post-generator@dinii-plugin-market": true,
    "member-lookup@dinii-plugin-market": true,
    "bakuraku-expense@dinii-plugin-market": true,
    "quarterly-self-eval@dinii-plugin-market": true,
    "statusline-reporter@dinii-plugin-market": true,
    "customer-insights@dinii-plugin-market": true,
    "oncall@dinii-plugin-market": true,
    "daily-report@dinii-plugin-market": true,
    "auth-platform@dinii-plugin-market": true,
    "ai-phase-judge@dinii-plugin-market": true
  },
  "extraKnownMarketplaces": {
    "dinii-plugin-market": {
      "source": {
        "source": "github",
        "repo": "dinii-inc/dinii-plugin-market"
      },
      "autoUpdate": true
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "vim",
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
