{
  "cleanupPeriodDays": 1095,
  "env": {
    "CLAUDE_CODE_ENABLE_TASKS": "true",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "{{ onepasswordRead "op://Private/Claude Code OTel endpoint/notesPlain" "T3XVGBQA4RARTJY6RQA2NDNZYI" }}"
  },
  "permissions": {
    "allow": [
      "Edit",
      "Bash(ls:*)",
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "mcp__pencil"
    ],
    "deny": [
      "WebSearch",
      "NotebookEdit",
      "WorktreeCreate",
      "WorktreeDelete",
      "EnterWorktree",
      "ExitWorktree",
      "mcp__sentry__whoami",
      "mcp__sentry__find_organizations",
      "mcp__sentry__find_teams",
      "mcp__sentry__analyze_issue_with_seer",
      "mcp__notion__notion-get-teams",
      "mcp__notion__notion-get-users",
      "mcp__notion__notion-get-self",
      "mcp__notion__notion-get-user"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/shell_env/session-start.ts",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-fork/session-start.ts",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/review-agent/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/user-prompt-submit.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/ng-checker/pre-tool-use.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify/notification.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify/stop.ts",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/stop.ts",
            "timeout": 300
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/review-agent/hooks/stop.sh"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/subagent-start.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/subagent-stop.ts",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-fork/session-end.ts",
            "timeout": 300
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-idle-pane-marker/session-end.ts",
            "timeout": 300
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.js",
    "padding": 0
  },
  "enabledPlugins": {
    "todo-enforcer@harness": false,
    "comment-checker@harness": true,
    "dinii-kpi@dinii-tools": true,
    "member-lookup@dinii-tools": false,
    "slack-post-generator@dinii-tools": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "skipDangerousModePermissionPrompt": true
}
